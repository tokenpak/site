---
import { config } from '../lib/config';

const navItems = [
  { label: 'Open Source',  href: '/open-source' },
  { label: 'Releases',     href: config.cta_urls.see_latest_release },
  { label: 'Docs',         href: config.cta_urls.read_docs },
  ...(config.feature_flags.show_product_page ? [{ label: 'Product', href: '/product' }] : []),
  ...(config.feature_flags.show_paid_page    ? [{ label: 'Pro',     href: config.cta_urls.explore_pro }] : []),
];
---
<header class="border-b border-tp-rule bg-tp-paper">
  <div class="mx-auto max-w-prose-wide px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
    {/* Split-color wordmark per 05 §4.1. Parent <a> carries the
        accessible name via aria-label; the two visible spans remain
        in reading order. The 'Pak' span's tp-accent-on-tp-paper
        contrast is the documented 05 §5.2 wordmark exception and is
        suppressed from the a11y audit via scripts/audit-a11y.ts
        exclude list. */}
    <a href="/" class="font-bold text-h3 no-underline shrink-0" aria-label={config.brand_name}>
      <span class="text-tp-ink">Token</span><span class="text-tp-accent" data-wordmark-accent>Pak</span>
    </a>
    <nav aria-label="Primary" class="flex items-center gap-4 sm:gap-6 text-small">
      {/* Auxiliary nav hidden below sm (640px). At 375px mobile the wordmark
          + Get Started CTA alone stay well within viewport. 22 §3.3 requires
          every page reachable within two clicks — Get Started links to docs
          quickstart which exposes the full nav on that side. */}
      <div class="hidden sm:flex items-center gap-6">
        {navItems.map((item) => (
          <a href={item.href} class="text-tp-ink no-underline hover:text-tp-accent">{item.label}</a>
        ))}
      </div>
      <a
        href={config.cta_urls.get_started}
        class="rounded-card bg-tp-accent px-3 py-2 sm:px-4 font-semibold text-tp-ink no-underline"
      >
        Get Started
      </a>
    </nav>
  </div>
</header>
