---
interface Props {
  language?: string;
  title?: string;
  copyable?: boolean;
}
const { language = 'bash', title, copyable = false } = Astro.props;
---
<figure class="rounded-card overflow-hidden border border-tp-rule">
  {title && (
    <figcaption class="flex items-center justify-between bg-tp-ink text-tp-paper text-caption font-mono px-4 py-2">
      <span>{title}</span>
      {/* Language label inherits figcaption's tp-paper-on-tp-ink (AA-compliant).
          Previous 'text-tp-mute' override was 2.98:1 on tp-ink (fails AA). */}
      <span class="opacity-80">{language}</span>
    </figcaption>
  )}
  <pre
    class="bg-tp-charcoal text-tp-paper text-small font-mono px-4 py-3 overflow-x-auto leading-relaxed"
    role="region"
    aria-label={title ? `${title} code block` : 'Code block'}
    tabindex="0"
  ><code><slot /></code></pre>
</figure>
