---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseCard from '../../components/ReleaseCard.astro';
import { publishedReleases, latestRelease } from '../../lib/releases';

const latest = latestRelease();
const allPublished = publishedReleases();
---
<BaseLayout title="Releases — TokenPak" description="Every TokenPak release, newest first.">
  <section class="mx-auto max-w-prose-wide px-6 pt-16 pb-8">
    <h1>Releases</h1>
    <p class="mt-2 text-tp-mute">Sourced from <a href="https://github.com/tokenpak/tokenpak/releases">GitHub Releases</a> on every publish. Regenerated by the site's sync workflow.</p>
  </section>

  {latest && (
    <section class="mx-auto max-w-prose-wide px-6 py-6">
      <h2>Latest</h2>
      <div class="mt-4">
        <ReleaseCard release={latest} />
      </div>
    </section>
  )}

  <section class="mx-auto max-w-prose-wide px-6 py-6">
    <h2>All releases</h2>
    {allPublished.length === 0 ? (
      <p class="mt-4 text-tp-mute">No releases yet. The homepage and this page will populate after the first sync run — see the <code class="font-mono">deploy</code> and <code class="font-mono">sync-release-data</code> workflows in the site repo.</p>
    ) : (
      <ul class="mt-4 space-y-4">
        {allPublished.map((r) => (
          <li><ReleaseCard release={r} compact /></li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
