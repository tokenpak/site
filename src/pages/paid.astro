---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { config } from '../lib/config';

// Pro feature groups sourced from 07 §5.1 + §5.2. No invented features;
// no public pricing per D1.a (2026-04-23 canonical decision).
const proGroups = [
  {
    title: 'Team scale',
    body:
      'Shared dashboard with multi-seat cost attribution. See which workloads, which engineers, which tools drive spend — without wiring a BI pipeline.',
  },
  {
    title: 'Operations',
    body:
      'Advanced routing policies: cost-aware fallbacks, SLA-aware failover across providers, tiered routing by workload kind. OSS routing gives you the rule surface; Pro gives you the policy tooling that runs on top.',
  },
  {
    title: 'Enterprise',
    body:
      'SSO for the dashboard, credential-rotation hooks, audit-log export. Priority support with an SLA. Compliance rulesets that plug into the compression pipeline.',
  },
  {
    title: 'Custom recipes',
    body:
      'Ship your own compression recipes alongside the 50 built-in OSS ones. Team-specific segmentation, domain-specific alias dictionaries, policy-constrained redaction for regulated workloads.',
  },
];

const noInPro = [
  'A different compression engine. Pro and OSS run the same engine; Pro layers team-scale + enterprise features on top.',
  'A different proxy. Same byte-preserved passthrough. Same local-first stance. Same telemetry store.',
  'A lock-in. Pro adds features; it never disables OSS capability or hides it behind a tier.',
];
---
<BaseLayout title="Pro — TokenPak" description="TokenPak Pro: team dashboards, advanced routing, enterprise credential management. OSS is the full product; Pro adds team-scale features on top.">
  <section class="mx-auto max-w-prose-wide px-6 pt-16 pb-8">
    <p class="text-caption text-tp-mute uppercase tracking-wide mb-2">Pro tier</p>
    <h1>TokenPak Pro.</h1>
    <p class="mt-6 text-body">
      Everything <a href="/open-source">the OSS core</a> ships — proxy, compression engine,
      client integrations, local dashboard, telemetry store, 50 built-in recipes — stays in
      place. Pro adds the features a team running TokenPak at scale needs: shared cost
      attribution, policy tooling, enterprise credential management, priority support.
    </p>
    <p class="mt-4 text-body text-tp-mute">
      Pro access is gated during v1. Drop us a line with how you're using TokenPak today and
      we'll follow up with credentials for <code class="font-mono">{config.private_index_url_public_label}</code>.
    </p>
    <a
      href={config.cta_urls.request_access}
      class="mt-6 inline-flex items-center rounded-card bg-tp-accent px-5 py-3 font-semibold text-tp-ink no-underline"
    >
      Request access
    </a>
  </section>

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <h2>What Pro adds</h2>
    <p class="mt-2 text-tp-mute">Four feature groups, layered on the same OSS core.</p>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {proGroups.map((g) => <FeatureCard title={g.title} body={g.body} />)}
    </div>
  </section>

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <h2>What Pro is not</h2>
    <ul class="mt-4 space-y-3">
      {noInPro.map((line) => (
        <li class="rounded-card border border-tp-rule p-4 bg-tp-paper text-body">{line}</li>
      ))}
    </ul>
    <p class="mt-4 text-small text-tp-mute">
      Side-by-side on the <a href="/open-source">OSS page</a>: the full feature comparison table.
    </p>
  </section>

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <h2>Install (once access is granted)</h2>
    <p class="mt-2 text-small text-tp-mute">
      <strong class="text-tp-ink">Pro</strong> is the tier name.
      <code class="font-mono">{config.package_paid}</code> is the package name. They are
      deliberately different per <a href={config.docs_base_url + '/'}>the naming rule</a>.
    </p>
    <p class="mt-4 text-small text-tp-mute">
      The real <code class="font-mono">{config.package_paid}</code> package is distributed from
      a private, license-gated index at <code class="font-mono">{config.private_index_url_public_label}</code>.
      Once you hold a Pro license, install it with:
    </p>
    <div class="mt-2">
      <CodeBlock language="bash" title="pip — licensed install">
{`pip install \\
    --index-url ${config.private_index_url_public_label} \\
    --extra-index-url https://pypi.org/simple \\
    ${config.package_paid}`}
      </CodeBlock>
    </div>
    <p class="mt-6 text-small text-tp-mute">
      If you ran <code class="font-mono">pip install tokenpak-paid-stub</code> from public
      PyPI first, you found the thin discovery stub we ship there. The stub prints the same
      guidance on <code class="font-mono">python -m tokenpak_paid_stub</code>. Two distinct
      package names keep pip's index resolution unambiguous — the stub never shadows the
      real paid package.
    </p>
  </section>

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <div class="rounded-card border border-tp-rule p-8 bg-tp-paper">
      <h2>Ready to try Pro?</h2>
      <p class="mt-2 text-body">
        Pricing is not public during v1. Write to us with your use case and we'll follow up
        with credentials and next steps.
      </p>
      <a
        href={config.cta_urls.request_access}
        class="mt-4 inline-flex items-center rounded-card bg-tp-accent px-5 py-3 font-semibold text-tp-ink no-underline"
      >
        Request access
      </a>
    </div>
  </section>
</BaseLayout>
