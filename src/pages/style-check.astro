---
/*
 * Dev-only swatch + type-scale audit page. Deleted in PR#10 before
 * the public-trust audit. Never linked from nav.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const palette = [
  { token: 'tp-ink',          hex: '#0B0F14', role: 'Primary text, hero UI' },
  { token: 'tp-paper',        hex: '#F6F7F9', role: 'Page background (light)' },
  { token: 'tp-charcoal',     hex: '#1A1F26', role: 'Page background (dark)' },
  { token: 'tp-accent',       hex: '#00C389', role: 'Identity / CTAs / links' },
  { token: 'tp-signal-value', hex: '#EDE085', role: 'Savings + value metrics' },
  { token: 'tp-warn',         hex: '#F5A623', role: 'Warnings, degraded' },
  { token: 'tp-danger',       hex: '#E5484D', role: 'Errors only' },
  { token: 'tp-mute',         hex: '#6B7280', role: 'Secondary text, gridlines' },
  { token: 'tp-rule',         hex: '#E4E7EB', role: 'Dividers, borders' },
];

const scales = [
  { step: 'display', sample: 'TokenPak' },
  { step: 'h1',      sample: 'Compression, caching, routing, telemetry.' },
  { step: 'h2',      sample: 'Section heading' },
  { step: 'h3',      sample: 'Subsection heading' },
  { step: 'body',    sample: 'Body copy at 1rem base.' },
  { step: 'small',   sample: 'Small / secondary copy.' },
  { step: 'caption', sample: 'Caption text.' },
];
---
<BaseLayout title="Style check — tokenpak">
  <main class="mx-auto max-w-prose-wide px-6 py-12 space-y-12">
    <header class="space-y-2">
      <p class="text-caption text-tp-mute uppercase tracking-wide">Dev-only. Removed in PR#10.</p>
      <h1>Brand token audit</h1>
      <p class="text-tp-mute">Every brand token from <code>05 §5.1</code> rendered on one page. Used to spot-check contrast, hex accuracy, and type-scale rhythm.</p>
    </header>

    <section>
      <h2>Palette</h2>
      <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {palette.map(({ token, hex, role }) => (
          <li class="rounded-card border border-tp-rule overflow-hidden">
            <div class={`h-16 bg-${token}`} style={`background-color: ${hex}`} aria-hidden="true"></div>
            <div class="p-4 space-y-1">
              <div class="font-mono text-small">{token}</div>
              <div class="font-mono text-caption text-tp-mute">{hex}</div>
              <div class="text-small">{role}</div>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Type scale</h2>
      <ul class="mt-4 divide-y divide-tp-rule">
        {scales.map(({ step, sample }) => (
          <li class="py-4 flex items-baseline gap-6">
            <span class="w-24 font-mono text-caption text-tp-mute shrink-0">{step}</span>
            <span class={`text-${step}`}>{sample}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Signal-color contract</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-card border border-tp-rule p-6 bg-tp-paper">
          <p class="text-small text-tp-mute">Primary CTA uses <code>tp-accent</code>:</p>
          <button class="mt-3 inline-flex items-center rounded-card bg-tp-accent px-5 py-2 font-semibold text-tp-ink">
            Get TokenPak
          </button>
        </div>
        <div class="rounded-card border border-tp-rule p-6 bg-tp-paper">
          <p class="text-small text-tp-mute">Savings number uses <code>tp-signal-value</code>:</p>
          <p class="mt-3 font-mono font-bold text-display" style="color: var(--tp-ink); background-color: var(--tp-signal-value); display: inline-block; padding: 0 0.5rem; border-radius: 4px;">
            $128 saved
          </p>
        </div>
      </div>
    </section>

    <footer class="text-caption text-tp-mute">
      Canonical source: <code>05-brand-style-guide.md §5.1</code>. Any change here must be proposed against that standard first.
    </footer>
  </main>
</BaseLayout>
