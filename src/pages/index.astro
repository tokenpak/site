---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ModuleCard from '../components/ModuleCard.astro';
import CTASection from '../components/CTASection.astro';
import ReleaseCard from '../components/ReleaseCard.astro';
import { latestRelease } from '../lib/releases';
import DocLinkCard from '../components/DocLinkCard.astro';
import { docsLinks } from '../lib/docs-links';

const latest = latestRelease();
const featuredDocs = docsLinks.slice(0, 6);

// Why-cards copy sourced verbatim from 07-messaging-positioning-guide.md §2
// proof points 2–5. Do not paraphrase — canonical phrasing lives there.
const whyCards = [
  {
    title: 'Low latency',
    body: 'Under 50ms compression overhead on typical agent prompts. Your agent does not feel slower.',
  },
  {
    title: 'One-command setup',
    body: 'pip install tokenpak && tokenpak setup. Interactive wizard detects your API keys, picks a compression profile, and starts the proxy. Per-client auto-integration (tokenpak integrate) is on the roadmap.',
  },
  {
    title: 'Works with what you already use',
    body: 'Claude Code, Cursor, Cline, Continue, Aider, OpenAI SDK, Anthropic SDK, LiteLLM, Codex. No plugin rewrites.',
  },
  {
    title: 'Local and private',
    body: 'No cloud component. No credentials stored. Requests still go to your model providers, but compression happens on your machine.',
  },
];

// How-it-works strip — three steps. Placeholder pending the real diagram in
// a later phase (kickoff §3 PR#6 calls out a stub here is acceptable).
const steps = [
  { label: 'Step 1', title: 'Install',   body: 'pip install tokenpak. Runs at 127.0.0.1 as a local proxy.' },
  { label: 'Step 2', title: 'Setup',     body: 'tokenpak setup — interactive wizard wires your keys + starts the proxy. Point your LLM client at http://127.0.0.1:8766 via one env var.' },
  { label: 'Step 3', title: 'Save',      body: 'Every request is compressed deterministically; savings logged locally.' },
];
---
<BaseLayout title="TokenPak — local LLM proxy">
  <Hero />

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <h2>Why TokenPak</h2>
    <p class="mt-2 text-tp-mute">Built for the parts of an agent workload you cannot renegotiate.</p>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {whyCards.map((card) => (
        <FeatureCard title={card.title} body={card.body} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-prose-wide px-6 py-8">
    <h2>How it works</h2>
    <p class="mt-2 text-tp-mute">Three steps. No cloud, no rewrites.</p>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
      {steps.map((step) => (
        <ModuleCard label={step.label} title={step.title} body={step.body} />
      ))}
    </div>
  </section>

  {latest && (
    <section class="mx-auto max-w-prose-wide px-6 py-8">
      <h2>Latest release</h2>
      <p class="mt-2 text-tp-mute">Refreshed automatically on every release + on a daily safety-net schedule.</p>
      <div class="mt-6">
        <ReleaseCard release={latest} />
      </div>
    </section>
  )}

  {featuredDocs.length > 0 && (
    <section class="mx-auto max-w-prose-wide px-6 py-8">
      <h2>Documentation highlights</h2>
      <p class="mt-2 text-tp-mute">Curated entry points sourced from <a href="https://github.com/tokenpak/docs">tokenpak/docs</a>.</p>
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {featuredDocs.map((link) => <DocLinkCard link={link} />)}
      </div>
    </section>
  )}

  <CTASection />
</BaseLayout>
