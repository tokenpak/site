{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tokenpak-site releases manifest",
  "description": "Build-time snapshot of GitHub Releases for tokenpak/tokenpak. Regenerated by scripts/sync-releases.ts. Consumed by src/pages/releases/index.astro + [version].astro + the homepage 'Latest Release' card. See 22-public-website-standard.md §5.4 and site design doc §4.1.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["version", "published_at", "title"],
    "properties": {
      "version":             { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
      "published_at":        { "type": "string", "format": "date-time" },
      "title":               { "type": "string", "minLength": 1 },
      "summary":             { "type": "string" },
      "body_markdown":       { "type": "string" },
      "changelog_url":       { "type": "string", "format": "uri" },
      "github_release_url":  { "type": "string", "format": "uri" },
      "pypi_url":            { "type": "string", "format": "uri" },
      "latest":              { "type": "boolean", "default": false },
      "prerelease":          { "type": "boolean", "default": false }
    }
  }
}
